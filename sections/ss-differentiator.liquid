{%- liquid
  assign bullet_indexes = '1,2,3' | split: ','
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style ss-diff"
  style="{% render 'spacing-style', settings: section.settings %}"
  data-testid="ss-differentiator"
>
  <div class="ss-diff__inner">
    <div class="ss-diff__intro">
      {%- if section.settings.heading != blank -%}
        <h2 class="ss-diff__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <div class="ss-diff__body">{{ section.settings.body }}</div>
      {%- endif -%}
    </div>

    <div class="ss-diff__cards">
      {%- for block in section.blocks -%}
        {%- if block.type == 'compare_card' -%}
          <div class="ss-diff__card{% if block.settings.accent %} ss-diff__card--accent{% endif %}" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <p class="ss-diff__card-title">{{ block.settings.title }}</p>
            {%- endif -%}
            <div class="ss-diff__shirt">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 200 | image_tag: widths: '100, 200', alt: block.settings.title }}
              {%- else -%}
                {% render 'ss-icon', name: 'shirt', width: 60 %}
              {%- endif -%}
            </div>
            <ul class="ss-diff__bullets">
              {%- for i in bullet_indexes -%}
                {%- assign text_key = 'bullet_' | append: i | append: '_text' -%}
                {%- assign positive_key = 'bullet_' | append: i | append: '_positive' -%}
                {%- assign bullet_text = block.settings[text_key] -%}
                {%- if bullet_text != blank -%}
                  <li class="ss-diff__bullet">
                    {%- if block.settings[positive_key] -%}
                      <span class="ss-diff__bullet-icon ss-diff__bullet-icon--yes">{% render 'ss-icon', name: 'check', width: 18 %}</span>
                    {%- else -%}
                      <span class="ss-diff__bullet-icon ss-diff__bullet-icon--no">{% render 'ss-icon', name: 'x', width: 18 %}</span>
                    {%- endif -%}
                    <span>{{ bullet_text }}</span>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
      <span class="ss-diff__vs" aria-hidden="true">VS</span>
    </div>

    <div class="ss-diff__features">
      {%- for block in section.blocks -%}
        {%- if block.type == 'feature' -%}
          <div class="ss-diff__feature" {{ block.shopify_attributes }}>
            <span class="ss-diff__feature-icon">
              {%- if block.settings.icon_image != blank -%}
                {{ block.settings.icon_image | image_url: width: 80 | image_tag: widths: '40, 80', class: 'ss-diff__feature-icon-img', alt: block.settings.label }}
              {%- else -%}
                {% render 'ss-icon', name: block.settings.icon, width: 28 %}
              {%- endif -%}
            </span>
            <div class="ss-diff__feature-text">
              {%- if block.settings.label != blank -%}
                <p class="ss-diff__feature-label">{{ block.settings.label }}</p>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="ss-diff__feature-desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .ss-diff__inner {
    display: grid;
    gap: 40px;
    grid-template-columns: 1fr;
  }

  .ss-diff__heading {
    margin: 0 0 16px;
    font-family: var(--font-heading--family);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.05;
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    color: var(--color-foreground-heading);
  }

  .ss-diff__body { color: var(--color-foreground); }
  .ss-diff__body > :first-child { margin-top: 0; }
  .ss-diff__body > :last-child { margin-bottom: 0; }

  .ss-diff__cards {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .ss-diff__card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 20px 16px;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    background-color: rgb(var(--color-foreground-rgb) / 0.03);
  }

  .ss-diff__card--accent {
    border-width: 2px;
    border-color: var(--color-foreground-heading);
  }

  .ss-diff__card-title {
    margin: 0;
    text-align: center;
    font-family: var(--font-heading--family);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
    color: var(--color-foreground-heading);
  }

  .ss-diff__shirt {
    display: grid;
    place-items: center;
    padding: 6px 0;
    color: var(--color-foreground);
  }

  .ss-diff__shirt img { width: 60px; height: 60px; object-fit: contain; }

  .ss-diff__bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 10px;
  }

  .ss-diff__bullet {
    display: flex;
    gap: 8px;
    align-items: flex-start;
    font-size: 0.8rem;
    line-height: 1.3;
    color: var(--color-foreground);
  }

  .ss-diff__bullet-icon { flex: 0 0 auto; display: inline-flex; margin-top: 1px; }
  .ss-diff__bullet-icon--yes { color: var(--color-foreground-heading); }
  .ss-diff__bullet-icon--no { color: var(--color-foreground); opacity: 0.4; }

  .ss-diff__vs {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background-color: var(--color-foreground-heading);
    color: var(--color-background);
    display: grid;
    place-items: center;
    font-family: var(--font-heading--family);
    font-weight: 700;
    font-size: 0.78rem;
    z-index: 2;
  }

  .ss-diff__features { display: grid; gap: 22px; }

  .ss-diff__feature { display: flex; gap: 14px; align-items: flex-start; }
  .ss-diff__feature-icon { flex: 0 0 auto; display: inline-flex; color: var(--color-foreground-heading); }
  .ss-diff__feature-icon-img { width: 28px; height: 28px; object-fit: contain; }

  .ss-diff__feature-label {
    margin: 0 0 3px;
    font-family: var(--font-heading--family);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.85rem;
    color: var(--color-foreground-heading);
  }

  .ss-diff__feature-desc { margin: 0; font-size: 0.85rem; color: var(--color-foreground); opacity: 0.8; }

  @media screen and (min-width: 1000px) {
    .ss-diff__inner {
      grid-template-columns: 0.9fr 1.25fr 1fr;
      align-items: start;
      gap: 48px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Differentiator",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "MORE THAN A LOGO ON A SHIRT."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Most team stores stop at basic logo placement. We create modern, wearable designs that build team pride and look great on and off the field.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "compare_card",
      "name": "Comparison card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "BASIC TEAM STORE" },
        { "type": "checkbox", "id": "accent", "label": "Highlight this card", "default": false },
        { "type": "image_picker", "id": "image", "label": "Shirt image (optional)" },
        { "type": "header", "content": "Points" },
        { "type": "text", "id": "bullet_1_text", "label": "Point 1", "default": "Plain logo on a blank tee" },
        { "type": "checkbox", "id": "bullet_1_positive", "label": "Point 1 positive", "default": false },
        { "type": "text", "id": "bullet_2_text", "label": "Point 2", "default": "Looks like every other store" },
        { "type": "checkbox", "id": "bullet_2_positive", "label": "Point 2 positive", "default": false },
        { "type": "text", "id": "bullet_3_text", "label": "Point 3", "default": "Worn on game day, then forgotten" },
        { "type": "checkbox", "id": "bullet_3_positive", "label": "Point 3 positive", "default": false }
      ]
    },
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "pencil", "label": "Pencil" },
            { "value": "shirt", "label": "Shirt" },
            { "value": "shield", "label": "Shield" },
            { "value": "calendar", "label": "Calendar" },
            { "value": "star", "label": "Star" },
            { "value": "eye", "label": "Eye" },
            { "value": "sparkles", "label": "Sparkles" }
          ],
          "default": "pencil"
        },
        { "type": "image_picker", "id": "icon_image", "label": "Custom icon image (overrides icon)" },
        { "type": "text", "id": "label", "label": "Label", "default": "DESIGNED, NOT DECORATED" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Original designs, not clip art." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Differentiator",
      "category": "Sideline Social",
      "blocks": [
        {
          "type": "compare_card",
          "settings": {
            "title": "BASIC TEAM STORE",
            "accent": false,
            "bullet_1_text": "Plain logo on a blank tee",
            "bullet_1_positive": false,
            "bullet_2_text": "Looks like every other store",
            "bullet_2_positive": false,
            "bullet_3_text": "Worn on game day, then forgotten",
            "bullet_3_positive": false
          }
        },
        {
          "type": "compare_card",
          "settings": {
            "title": "SIDELINE SOCIAL",
            "accent": true,
            "bullet_1_text": "Designed, not decorated",
            "bullet_1_positive": true,
            "bullet_2_text": "Modern athletic style",
            "bullet_2_positive": true,
            "bullet_3_text": "Worn beyond game day",
            "bullet_3_positive": true
          }
        },
        {
          "type": "feature",
          "settings": { "icon": "pencil", "label": "DESIGNED, NOT DECORATED", "description": "Original designs, not clip art." }
        },
        {
          "type": "feature",
          "settings": { "icon": "shirt", "label": "MODERN ATHLETIC LOOKS", "description": "Trend-aware styles parents actually want." }
        },
        {
          "type": "feature",
