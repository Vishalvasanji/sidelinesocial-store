{%- liquid
  assign columns = section.settings.columns | default: 6
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style ss-cats"
  style="{% render 'spacing-style', settings: section.settings %} --ss-cats-columns: {{ columns }};"
  data-testid="ss-categories"
>
  {%- if section.settings.heading != blank -%}
    <h2 class="ss-cats__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="ss-cats__grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign coll = block.settings.collection
        assign label = block.settings.label
        if label == blank and coll != blank
          assign label = coll.title
        endif
        assign url = block.settings.link
        if url == blank and coll != blank
          assign url = coll.url
        endif
        assign img = block.settings.image
        if img == blank and coll != blank
          assign img = coll.featured_image
        endif
      -%}
      <a class="ss-cats__card" href="{{ url | default: '#' }}" {{ block.shopify_attributes }}>
        <div class="ss-cats__media">
          {%- if img != blank -%}
            {{
              img
              | image_url: width: 600
              | image_tag:
                widths: '200, 300, 450, 600',
                sizes: '(min-width: 750px) 18vw, 45vw',
                class: 'ss-cats__img',
                alt: label
            }}
          {%- else -%}
            {{ 'product-apparel-1' | placeholder_svg_tag: 'ss-cats__img placeholder-svg' }}
          {%- endif -%}
        </div>
        <span class="ss-cats__label-row">
          <span class="ss-cats__label">{{ label | default: 'Category' }}</span>
          <span class="ss-cats__arrow" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </span>
      </a>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .ss-cats__heading {
    margin: 0 0 32px;
    text-align: center;
    font-family: var(--font-heading--family);
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--color-foreground-heading);
  }

  .ss-cats__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .ss-cats__card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-decoration: none;
    color: inherit;
  }

  .ss-cats__media {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 8px;
    background-color: rgb(var(--color-foreground-rgb) / 0.06);
  }

  .ss-cats__media :is(img, svg) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .ss-cats__card:hover .ss-cats__media :is(img, svg) {
    transform: scale(1.04);
  }

  .ss-cats__label-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .ss-cats__label {
    font-family: var(--font-heading--family);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.8rem;
    color: var(--color-foreground-heading);
  }

  .ss-cats__arrow {
    display: inline-flex;
    flex: 0 0 auto;
    color: var(--color-foreground-heading);
    transition: transform 0.15s ease;
  }

  .ss-cats__card:hover .ss-cats__arrow {
    transform: translateX(3px);
  }

  @media screen and (min-width: 750px) {
    .ss-cats__grid {
      grid-template-columns: repeat(var(--ss-cats-columns, 6), 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Shop by category",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SHOP BY CATEGORY"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 6
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection (sets image, title and link)" },
        { "type": "text", "id": "label", "label": "Label (overrides collection title)", "default": "YOUTH GEAR" },
        { "type": "image_picker", "id": "image", "label": "Image (overrides collection image)" },
        { "type": "url", "id": "link", "label": "Link (overrides collection link)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by category",
      "category": "Sideline Social",
      "blocks": [
        { "type": "category", "settings": { "label": "YOUTH GEAR" } },
        { "type": "category", "settings": { "label": "WOMEN'S GEAR" } },
        { "type": "category", "settings": { "label": "ADULT / UNISEX" } },
        { "type": "category", "settings": { "label": "HOODIES" } },
        { "type": "category", "settings": { "label": "TEES" } },
        { "type": "category", "settings": { "label": "NIKE GEAR" } }
      ]
    }
  ]
}
{% endschema %}
